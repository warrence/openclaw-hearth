NODE_ENV=development
PORT=3001
APP_NAME=hearth-api-nest
APP_HOST=0.0.0.0
APP_PREFIX=
LOG_LEVEL=debug
AUTH_SESSION_SECRET=hearth-api-nest:session:dev-secret
AUTH_SESSION_COOKIE_NAME=hearth_nest_session
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_MAX_AGE_SECONDS=2592000

# OpenClaw gateway connection — required
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Agent and model presets are configured in the Hearth dashboard
# and saved to ~/.openclaw/hearth.json — no need to set them here.
# These are only used as last-resort fallbacks if hearth.json is missing.
OPENCLAW_AGENT_TIMEOUT_MS=900000
OPENCLAW_RESPONSES_HTTP_ENABLED=true
OPENCLAW_RESPONSES_HTTP_PATH=/v1/responses

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=hearth
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_AUTO_RUN_MIGRATIONS=false
DATABASE_SYNCHRONIZE=false

# Optional complete connection string. If provided, it overrides host/port/name/user/password.
# Example: postgres://postgres:postgres@127.0.0.1:5432/hearth
DATABASE_URL=
