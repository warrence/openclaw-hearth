{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "openclaw/*": ["/opt/homebrew/lib/node_modules/openclaw/*"],
      "openclaw": ["/opt/homebrew/lib/node_modules/openclaw"]
    }
  },
  "include": ["src"]
}
